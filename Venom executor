function destroyGui()
    destroying = true

    RunService:UnbindFromRenderStep("DRAWING")
    RunService:UnbindFromRenderStep("Hazard")

    for _, c in connections do
        if typeof(c) == "RBXScriptConnection" then
            c:Disconnect()
        end
    end
    table.clear(connections)

    for obj, line in pairs(tracers) do
        line:Destroy()
        tracers[obj] = nil
    end

    closestGiftTracer:Destroy()
    medalTracer:Destroy()

    if tripmineprots then tripmineprots:Destroy() end
    if bulletprots then bulletprots:Destroy() end
    if velocityPart then velocityPart:Destroy() end

    stopCurrent()

    for _, inst in pairs(newInstances) do
        if typeof(inst) == "Instance" and inst.Parent then
            inst:Destroy()
        end
    end
    table.clear(newInstances)

    Rayfield:Destroy()

    if notifOn then
        StarterGui:SetCore("SendNotification", {
            Title = "NULL GUI",
            Text = "GUI destroyed.",
            Duration = 3
        })
    end
end


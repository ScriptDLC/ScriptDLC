-- запас вокруг мины (радиус взрыва + буфер) и вокруг врага
local TRIPMINE_PADDING = 7
local ENEMY_PADDING = 1
local PLAYER_RADIUS = 2.5
local SPAWN_PADDING = 3

-- проверяет "коридор" движения fromPos -> toPos на пересечение с препятствиями
local function segmentBlocked(fromPos, toPos, obstacles, padding)
    padding = padding or 0

    local minX = math.min(fromPos.X, toPos.X) - PLAYER_RADIUS
    local minY = math.min(fromPos.Y, toPos.Y) - PLAYER_RADIUS
    local minZ = math.min(fromPos.Z, toPos.Z) - PLAYER_RADIUS
    local maxX = math.max(fromPos.X, toPos.X) + PLAYER_RADIUS
    local maxY = math.max(fromPos.Y, toPos.Y) + PLAYER_RADIUS
    local maxZ = math.max(fromPos.Z, toPos.Z) + PLAYER_RADIUS

    for _, obj in ipairs(obstacles) do
        if obj and obj.Parent then
            local pos  = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
            local size = obj:IsA("Model") and obj:GetExtentsSize()    or obj.Size
            local ex, ey, ez = size.X/2 + padding, size.Y/2 + padding, size.Z/2 + padding

            local overlapX = maxX >= pos.X - ex and minX <= pos.X + ex
            local overlapY = maxY >= pos.Y - ey and minY <= pos.Y + ey
            local overlapZ = maxZ >= pos.Z - ez and minZ <= pos.Z + ez

            if overlapX and overlapY and overlapZ then
                return true, obj, pos, Vector3.new(ex, ey, ez)
            end
        end
    end

    return false
end

local function getClosestGift(giftList, liveFolder)
    local char = getChar(plr)
    local root = getRoot(char)
    if not root then return end

    local rootPos = root.Position
    local closest, shortest = nil, math.huge

    -- ALWAYS scan the whole live folder so nothing is left uncollected
    -- after many uses (the old cache could go stale and skip remaining gifts).
    local source = (liveFolder and liveFolder:GetChildren()) or giftList
    for _, gift in ipairs(source) do
        if gift and gift.Parent and gift.Transparency == 0 and gift:FindFirstChild("Collect", true) then
            local dist = (gift.Position - rootPos).Magnitude
            if dist < shortest then
                shortest = dist
                closest = gift
            end
        end
    end

    return closest, shortest
end


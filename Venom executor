-- goTo переписан: список мин всегда актуальный, при блокировке путь идёт НАД миной (обход сверху),
-- телепорт "сквозь мину" убран.
local function goTo(part)
    if not part then return end
    local char = getChar(plr)
    local root, hitbox = getRoot(char)
    if not root or not hitbox then return end

    -- ВСЕГДА берём актуальный список (старый кэш ловил не все мины)
    local activeTripmines = getActiveTripmines()
    local activeEnemies   = enemies:GetChildren()

    -- запоминаем мины, уже учтённые при построении пути, чтобы
    -- монитор НЕ отменял обход из-за той же мины, которую мы облетаем
    local knownMines = {}
    for _, m in ipairs(activeTripmines) do
        knownMines[m] = true
    end

    local pos = part:IsA("Model") and part:GetPivot().Position or part.Position
    if part.Name == "Spawn" then pos += Vector3.new(0, 4, 0) end

    local diff = pos - root.Position
    local dist = diff.Magnitude
    if dist == 0 or dist >= 10000 then return end

    -- разворот в сторону движения
    root.CFrame = CFrame.new(root.Position, root.Position + diff.Unit) * CFrame.Angles(0, math.rad(90), 0)

    -- по умолчанию прямой путь
    local waypoints = { pos }

    local blocked, _obj, obsPos, obsExt = segmentBlocked(root.Position, pos, activeTripmines, TRIPMINE_PADDING)
    if not blocked then
        blocked, _obj, obsPos, obsExt = segmentBlocked(root.Position, pos, activeEnemies, ENEMY_PADDING)
    end
    -- while collecting golden gifts, treat spawn (the anti-void point) as an obstacle
    if not blocked and avoidSpawnDuringGolden and spawnPart then
        blocked, _obj, obsPos, obsExt = segmentBlocked(root.Position, pos, { spawnPart }, SPAWN_PADDING)
    end

    if blocked and obsPos then
        -- ведём путь НАД препятствием: вверх -> вдоль -> вниз к подарку.
        -- никогда не опускаемся ниже уровня спавна, чтобы не застрять под картой
        local groundY = spawnPart.Position.Y
        local overY = math.max(obsPos.Y + obsExt.Y + 14, root.Position.Y, pos.Y, groundY)
        -- STRONGER mine protection: rise above EVERY mine under the horizontal corridor
        do
            local minX = math.min(root.Position.X, pos.X) - PLAYER_RADIUS
            local maxX = math.max(root.Position.X, pos.X) + PLAYER_RADIUS
            local minZ = math.min(root.Position.Z, pos.Z) - PLAYER_RADIUS
            local maxZ = math.max(root.Position.Z, pos.Z) + PLAYER_RADIUS
            for _, m in ipairs(activeTripmines) do
                if m and m.Parent then
                    local mp = m:IsA("Model") and m:GetPivot().Position or m.Position
                    local ms = m:IsA("Model") and m:GetExtentsSize() or m.Size
                    local ex = ms.X/2 + TRIPMINE_PADDING
                    local ez = ms.Z/2 + TRIPMINE_PADDING
                    if maxX >= mp.X - ex and minX <= mp.X + ex and maxZ >= mp.Z - ez and minZ <= mp.Z + ez then
                        local top = mp.Y + ms.Y/2 + TRIPMINE_PADDING + 8
                        if top > overY then overY = top end
                    end
                end
            end
        end
        waypoints = {
            Vector3.new(root.Position.X, overY, root.Position.Z),
            Vector3.new(pos.X,           overY, pos.Z),
            pos,
        }
    end

    for _, wp in ipairs(waypoints) do
        local d = (wp - root.Position).Magnitude
        if d > 0.05 and d < 10000 then
            local info   = TweenInfo.new(d / 120, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
            local tween  = TweenService:Create(root,   info, { Position = wp })
            local htween = TweenService:Create(hitbox, info, { Position = wp })
            tween:Play()
            htween:Play()

            -- следим за НОВЫМИ минами прямо во время движения
            local cancelled = false
            task.spawn(function()
                while tween.PlaybackState == Enum.PlaybackState.Playing do
                    -- отменяем только из-за НОВОЙ мины (не той, что уже облетаем)
                    local newMines = {}
                    for _, m in ipairs(getActiveTripmines()) do
                        if not knownMines[m] then
                            newMines[#newMines+1] = m
                        end
                    end
                    if #newMines > 0 and segmentBlocked(root.Position, wp, newMines, TRIPMINE_PADDING) then
                        tween:Cancel()
                        htween:Cancel()
                        cancelled = true
                        break
                    end
                    task.wait(0.03)
                end
            end)

            -- ждём завершения твина БЕЗ зависаний:
            -- выходим при смерти / исчезновении рута / выключенном сборе или по таймауту
            local dur = d / 120
            local elapsed = 0
            while tween.PlaybackState == Enum.PlaybackState.Playing do
                if not tweening or not root.Parent or not hitbox.Parent then
                    tween:Cancel()
                    htween:Cancel()
                    return
                end
                elapsed += task.wait()
                -- страховка от вечного зависания: твин не должен идти дольше своей длительности + 1.5с
                if elapsed > dur + 1.5 then
                    tween:Cancel()
                    htween:Cancel()
                    break
                end
            end
            hitbox.Position = root.Position

            if cancelled then
                -- появилась новая мина на пути — уходим вниз и выходим,
                -- следующий тик collect() перестроит путь заново
                -- не падаем вниз, просто выходим — collect() перестроит путь с текущей точки
                hitbox.Position = root.Position
                return
            end
        end
    end
end




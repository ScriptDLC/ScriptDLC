local function collect(which)
    -- fresh start: clear any previous cancel request
    cancelRequested = false
    if magSlider then
        magSlider:Set(5)
    end

    local function collectGolden()
        if tweening then
            if notifOn then
                notif("Already collecting.", "Collection System")
            end
            return
        end
        tweening = true
        avoidSpawnDuringGolden = true   -- go around spawn while collecting golden
        local startRefreshing
        local emptyChecks = 0
        local finishedGolden = false
        local goldCounter = counters:FindFirstChild("GoldenGift")
        local lastCollected = (goldCounter and goldCounter:GetAttribute("Collected")) or 0
        local lastProgress = tick()

        while tweening and not cancelRequested do
            local char = getChar(plr)
            local root = getRoot(char)
            if root then root.AssemblyLinearVelocity = Vector3.new(0,0,0) end

            -- watchdog: fly to spawn once no more golden are reachable
            -- (required amount reached, OR no new golden collected for 15s = stuck/done)
            if goldCounter then
                local now = goldCounter:GetAttribute("Collected") or 0
                if now > lastCollected then
                    lastCollected = now
                    lastProgress = tick()
                end
                local maxg = goldCounter:GetAttribute("MaxGifts")
                if (maxg and maxg > 0 and now >= maxg) or (tick() - lastProgress > 15) then
                    finishedGolden = true
                    break
                end
            end

            if not startRefreshing then
                refreshGifts(true, true)
            elseif tick() - startRefreshing >= 15 then
                startRefreshing = tick()
                refreshGifts(true, true)
            end

            local gift = getClosestGift(availableGoldenGifts, goldengifts)
            if not gift then
                -- re-check golden gifts every time; do not stop instantly
                if root then
                    emptyChecks += 1
                else
                    emptyChecks = 0
                end
                if emptyChecks >= 60 then
                    if notifOn then
                        notif("no golden gifts left", "Gift Not Found")
                    end
                    finishedGolden = true
                    break
                end
                task.wait(.1)
                continue
            end
            emptyChecks = 0
            if not startRefreshing then
                startRefreshing = tick()
            end

            -- защита: ошибка внутри goTo не должна убить сбор и оставить tweening = true
            local ok, err = pcall(goTo, gift)
            if not ok then
                warn("[NULL GUI] goTo error:", err)
            end

            task.wait(.02)
        end
        avoidSpawnDuringGolden = false

        -- all golden collected (nothing left) -> auto-fly to spawn (retry until we actually arrive)
        if finishedGolden and not cancelRequested then
            tweening = true
            if notifOn then
                notif("All golden collected. Flying to spawn.", "Collection System")
            end
            for _ = 1, 80 do
                if cancelRequested or not tweening then break end
                local sroot = getRoot(getChar(plr))
                if sroot and spawnPart and (sroot.Position - spawnPart.Position).Magnitude <= 12 then
                    break
                end
                pcall(goTo, spawnPart)
                task.wait(.1)
            end
        end

        tweening = false
    end

    local function collectNormal(getGoldenAfter)
        if tweening then
            if notifOn then
                notif("Already collecting.", "Collection System")
            end
            return
        end
        tweening = true
        local startRefreshing
        local emptyChecks = 0

        while tweening and not cancelRequested do
            local char = getChar(plr)
            local root = getRoot(char)
            if root then root.AssemblyLinearVelocity = Vector3.new(0,0,0) end

            if not startRefreshing then
                refreshGifts(true, true)
            elseif tick() - startRefreshing >= 15 then
                startRefreshing = tick()
                refreshGifts(true, true)
            end

            local gift = getClosestGift(availableNormalGifts, gifts)
            if not gift then
                -- re-check normal gifts every time; do not stop instantly
                if root then
                    emptyChecks += 1
                else
                    emptyChecks = 0
                end
                if emptyChecks >= 60 then
                    if notifOn then
                        notif("no gifts left", "Gift Not Found")
                    end
                    break
                end
                task.wait(.1)
                continue
            end
            emptyChecks = 0
            if not startRefreshing then
                startRefreshing = tick()
            end

            -- защита: ошибка внутри goTo не должна убить сбор и оставить tweening = true
            local ok, err = pcall(goTo, gift)
            if not ok then
                warn("[NULL GUI] goTo error:", err)
            end

            task.wait(.02)
        end
        tweening = false
        if getGoldenAfter then task.wait(3) collectGolden() end
    end

    if which == "normal" then
        collectNormal()
    elseif which == "golden" then
        collectGolden()
    end
end


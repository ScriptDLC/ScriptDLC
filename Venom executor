RunService:BindToRenderStep("DRAWING", Enum.RenderPriority.Camera.Value, function()
    local char = getChar(plr)
    local root = getRoot(char)
    if not root then return end

    -- Cadence Instrument ESP
    if instrumentesp then
        local cadence = enemies:FindFirstChild("Cadence")
        if cadence then
            for _, inst in cadence:GetChildren() do
                if inst:IsA("BasePart") and inst.Name == "Instrument" then
                    if not tracers[inst] then
                        createTracer(inst)
                    end

                    local line = tracers[inst]
                    local screenPos, visible = Camera:WorldToViewportPoint(inst.Position)

                    if visible then
                        line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        line.To = Vector2.new(screenPos.X, screenPos.Y)
                        line.Visible = true
                    else
                        line.Visible = false
                    end
                end
            end
        end

        for obj, line in pairs(tracers) do
            if not obj.Parent then
                line:Destroy()
                tracers[obj] = nil
            end
        end
    end

    -- Closest Gift Tracer ESP
    if cesp then
        local gift = getClosestAnyGift()
        if gift then
            local screenPos, visible = Camera:WorldToViewportPoint(gift.Position)
            if visible then
                closestGiftTracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                closestGiftTracer.To = Vector2.new(screenPos.X, screenPos.Y)
                closestGiftTracer.Visible = true

                if not cgb then
                    cgb = Instance.new("BoxHandleAdornment")
                    cgb.Size = Vector3.new(3, 3, 3)
                    cgb.Color3 = Color3.new(1, 1, 0)
                    cgb.Transparency = 0.5
                    cgb.AlwaysOnTop = true
                    cgb.ZIndex = 0
                    cgb.Parent = velocityPart
                end
                cgb.Adornee = gift
            else
                closestGiftTracer.Visible = false
            end
        else
            closestGiftTracer.Visible = false
            if cgb then cgb.Adornee = nil end
        end
    end

    -- Medal ESP
    if mesp then
        local medal = beacons:FindFirstChild("Medal")
        if medal then
            local screenPos, visible = Camera:WorldToViewportPoint(medal.Position)
            if visible then
                medalTracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                medalTracer.To = Vector2.new(screenPos.X, screenPos.Y)
                medalTracer.Visible = true

                if not mb then
                    mb = Instance.new("BoxHandleAdornment")
                    mb.Size = Vector3.new(3, 3, 3)
                    mb.Color3 = Color3.new(0.75, 0.75, 0.75)
                    mb.Transparency = 0.5
                    mb.AlwaysOnTop = true
                    mb.ZIndex = 0
                    mb.Parent = velocityPart
                end
                mb.Adornee = medal
            else
                medalTracer.Visible = false
            end
        else
            medalTracer.Visible = false
            if mb then mb.Adornee = nil end
        end
    end

    -- Velocity Visualizer
    if velov then
        local vel = root.AssemblyLinearVelocity
        if vel.Magnitude > 0.1 then
            velocityPart.Size = Vector3.new(0.2, 0.2, vel.Magnitude / 4)
            velocityPart.CFrame = CFrame.new(root.Position, root.Position + vel) * CFrame.new(0, 0, -vel.Magnitude / 8)
            vpBox.Size = velocityPart.Size
            vpBox.Visible = true
        else
            vpBox.Visible = false
        end
    else
        vpBox.Visible = false
    end

    -- Visible Hitbox
    if visibleHitbox then
        local _, hitbox = getRoot(char)
        if hitbox then
            hitbox.Transparency = 0.5
        end
    end
end)

RunService:BindToRenderStep("Hazard", Enum.RenderPriority.Camera.Value + 1, function()
    local char = getChar(plr)
    local root = getRoot(char)
    if not root then return end

    -- Tripmine Protection
    if pt then
        for _, trip in getActiveTripmines() do
            protectTripmine(trip)
        end
    end

    -- Guardian Bullet Protection
    if pb then
        for _, b in bullets:GetChildren() do
            if b.Transparency ~= 1 then
                protectBullet(b)
            end

            local dir = (root.Position - b.Position)
            if dir.Magnitude < 15 and dir.Magnitude > 0 then
                local pushDir = dir.Unit
                if not isdirectionsafetopushfromguardianbullet(root.Position, pushDir) then
                    root.Position += pushDir * 3
                end
            end
        end
    end

    -- Anti Void
    if av then
        if root.Position.Y <= workspace.KillVoid.Position.Y + 10 then
            if antiVoidSelection == 1 then
                local pos = spawnPart.Position + Vector3.new(0, 4, 0)
                root.Position = pos
            elseif antiVoidSelection == 2 then
                root.AssemblyLinearVelocity = Vector3.new(0, lp, 0)
            elseif antiVoidSelection == 3 then
                local gift = getClosestAnyGift()
                if gift then
                    root.Position = gift.Position
                else
                    root.Position = spawnPart.Position + Vector3.new(0, 4, 0)
                end
            end
        end
    end

    -- Glider Boost
    if gliderBoost then
        root.AssemblyLinearVelocity = Camera.CFrame.LookVector * 100
    end

    -- Razorbloom destroy
    if nrb then
        local razor = pads:FindFirstChild("Razorbloom")
        if razor then
            razor:Destroy()
        end
    end
end)


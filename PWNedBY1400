local Players, RunService = game:GetService("Players"), game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local esp = {}
local enabled = false
local conn = nil

local function isKiller(p)
    local char = p and p.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth > 130
end

local function getName(p)
    return pcall(function() return p.DisplayName ~= "" and p.DisplayName or p.Name end) and p.Name
end

local function remove(p)
    if esp[p] then
        for _, obj in pairs(esp[p]) do
            pcall(function() obj:Destroy() end)
        end
        esp[p] = nil
    end
end

local function create(p)
    if p == LocalPlayer or not p.Character then return end
    remove(p)
    local char = p.Character
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end
    local killer = isKiller(p)
    local color = killer and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 150, 255)
    local name = getName(p) or p.Name
    local hl = Instance.new("Highlight")
    hl.Name = "ESP_" .. p.Name
    hl.Adornee = char
    hl.FillColor = color
    hl.OutlineColor = color
    hl.FillTransparency = 0.7
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = workspace.CurrentCamera
    local bb = Instance.new("BillboardGui")
    bb.Name = "Name_" .. p.Name
    bb.Adornee = root
    bb.Size = UDim2.new(0, 200, 0, 30)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 500
    bb.LightInfluence = 0
    bb.Parent = workspace.CurrentCamera
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.Text = killer and name .. "\n[KILLER]" or name
    txt.TextColor3 = color
    txt.TextSize = 14
    txt.Font = Enum.Font.GothamBold
    txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    txt.TextStrokeTransparency = 0
    txt.Parent = bb
    esp[p] = {highlight = hl, billboard = bb, label = txt}
end

local function update()
    for p, obj in pairs(esp) do
        if not p or not p.Parent or not p.Character then
            remove(p)
        elseif obj.highlight and obj.highlight.Parent then
            obj.highlight.Adornee = p.Character
            if obj.billboard then
                local root = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("Head")
                if root then obj.billboard.Adornee = root end
            end
            local killer = isKiller(p)
            local color = killer and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 150, 255)
            local name = getName(p) or p.Name
            if obj.highlight then
                obj.highlight.FillColor = color
                obj.highlight.OutlineColor = color
            end
            if obj.label then
                obj.label.TextColor3 = color
                obj.label.Text = killer and name .. "\n[KILLER]" or name
            end
        end
    end
end

local function enable()
    if enabled then return end
    enabled = true
    for p, _ in pairs(esp) do remove(p) end
    esp = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then spawn(function() create(p) end) end
    end
    Players.PlayerAdded:Connect(function(p)
        wait(1)
        if enabled then create(p) end
    end)
    Players.PlayerRemoving:Connect(function(p)
        if enabled then remove(p) end
    end)
    for _, p in pairs(Players:GetPlayers()) do
        p.CharacterAdded:Connect(function()
            wait(0.5)
            if enabled then create(p) end
        end)
    end
    conn = RunService.RenderStepped:Connect(function()
        if enabled then update() else if conn then conn:Disconnect() end end
    end)
end

local function disable()
    enabled = false
    if conn then conn:Disconnect() conn = nil end
    for p, _ in pairs(esp) do remove(p) end
    esp = {}
end

local Toggle = Tab:Toggle({
    Title = "ESP",
    Desc = "Buggy workz on mobile..",
    Icon = "badge-check",
    Type = "Checkbox",
    Value = false,
    Callback = function(state)
        if state then enable() else disable() end
    end
})


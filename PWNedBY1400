_G.MaxStaminaValue = 100
_G.StaminaBoostValue = 1

local maxStaminaConn = nil
local speedMultConn = nil

local function getSpeedFolder()
    local living = workspace:FindFirstChild("Living")
    if not living then return nil end
    local playerFolder = living:FindFirstChild(LocalPlayer.Name)
    if not playerFolder then return nil end
    local values = playerFolder:FindFirstChild("Values")
    if not values then return nil end
    return values:FindFirstChild("Speed")
end

local function hookStamina()
    if maxStaminaConn then pcall(function() maxStaminaConn:Disconnect() end) end
    if speedMultConn then pcall(function() speedMultConn:Disconnect() end) end
    maxStaminaConn = nil
    speedMultConn = nil

    task.spawn(function()
        local attempts = 0
        while attempts < 100 do
            task.wait(0.1)
            attempts = attempts + 1

            pcall(function()
                local speed = getSpeedFolder()
                if not speed then return end

                local maxStamina = speed:FindFirstChild("MaxStamina")
                if maxStamina and maxStamina:IsA("NumberValue") and not maxStaminaConn then
                    -- Сначала 100, потом через 8 сек значение со слайдера
                    maxStamina.Value = 100
                    task.delay(6.5, function()
                        pcall(function()
                            maxStamina.Value = _G.MaxStaminaValue
                        end)
                    end)

                    maxStaminaConn = maxStamina.Changed:Connect(function(v)
                        if v ~= _G.MaxStaminaValue then
                            task.defer(function()
                                pcall(function()
                                    maxStamina.Value = _G.MaxStaminaValue
                                end)
                            end)
                        end
                    end)
                end

                local speedMult = speed:FindFirstChild("SpeedMultiplier")
                if speedMult and speedMult:IsA("NumberValue") and not speedMultConn then
                    speedMult.Value = _G.StaminaBoostValue
                    speedMultConn = speedMult.Changed:Connect(function(v)
                        if v ~= _G.StaminaBoostValue then
                            task.defer(function()
                                pcall(function()
                                    speedMult.Value = _G.StaminaBoostValue
                                end)
                            end)
                        end
                    end)
                end

                if maxStaminaConn and speedMultConn then
                    attempts = 999
                end
            end)
        end
    end)
end

hookStamina()

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    hookStamina()
end)

